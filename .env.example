# =============================================================================
# LA CASA DEL SUELO RADIANTE - Variables de entorno
# Copia este archivo a .env y rellena los valores (nunca subas .env al repo).
# =============================================================================

# --- Supabase (obligatorio) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- URL de la aplicación (obligatorio en producción) ---
NEXT_PUBLIC_APP_URL=https://www.lacasadelsueloradiante.es

# --- Redsys (pago con tarjeta) ---
REDSYS_MERCHANT_CODE=343218590
REDSYS_TERMINAL=001
REDSYS_SECRET_KEY=tu_clave_SHA256_de_Redsys
REDSYS_CURRENCY=978
REDSYS_ENVIRONMENT=production
# URL que tienes registrada en el panel de Redsys (callback, OK, KO). Si en Redsys está sin www, ponla aquí:
REDSYS_MERCHANT_URL=https://lacasadelsueloradiante.es

# --- Email (notificaciones, recuperación de contraseña) ---
# Servidor salida: lacasadelsueloradiante.es | SMTP 465 (SSL)
EMAIL_HOST=lacasadelsueloradiante.es
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=consultas@lacasadelsueloradiante.es
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=consultas@lacasadelsueloradiante.es
EMAIL_FROM_NAME=La Casa del Suelo Radiante
EMAIL_ADMIN_ADDRESS=consultas@lacasadelsueloradiante.es

# --- Opcionales ---
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium  # Solo si usas PDF con Puppeteer
# NODE_ENV=production
